    "lucide-react": "^0.577.0",
    "next": "16.2.2",
    "next-nprogress-bar": "^2.4.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-csv": "^2.2.2",
    "react-dom": "19.2.4",
