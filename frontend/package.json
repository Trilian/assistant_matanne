{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --env-file ../.env.local",
    "build": "next build --webpack",
    "build:local": "next build --webpack --env-file ../.env.local",
    "start": "next start --env-file ../.env.local",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual-regression.spec.ts --project=chromium",
    "test:visual:update": "playwright test e2e/visual-regression.spec.ts --project=chromium --update-snapshots",
    "analyze": "ANALYZE=true next build --webpack --env-file ../.env.local",
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api-generated.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:generate": "typedoc"
  },
  "dependencies": {
