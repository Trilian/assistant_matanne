{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --env-file ../.env.local",
    "build": "next build",
    "build:local": "next build --env-file ../.env.local",
    "start": "next start --env-file ../.env.local",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual-regression.spec.ts --project=chromium",
    "test:visual:update": "playwright test e2e/visual-regression.spec.ts --project=chromium --update-snapshots",
    "analyze": "ANALYZE=true next build --env-file ../.env.local",
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api-generated.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.94.5",
    "@types/leaflet": "^1.9.21",
    "@zxing/browser": "^0.1.5",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-nprogress-bar": "^2.4.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-csv": "^2.2.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
